# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGODB_DB=healthportal

# JWT Secret - Generate a strong random string for production
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate-a-strong-random-secret-key-minimum-32-characters-long

# Next.js Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Email Configuration (for future features)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=

# Optional: Redis Configuration (for production caching)
# REDIS_URL=redis://localhost:6379

# Optional: File Upload Configuration
# MAX_FILE_SIZE=10485760
# UPLOAD_DIR=./uploads

